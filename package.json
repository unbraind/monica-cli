{
  "name": "monica-cli",
  "version": "2026.3.6-2",
  "description": "CLI interface for Monica CRM API - optimized for agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "monica": "./dist/index.js",
    "monica-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "bun dist/index.js",
    "dev": "bun --bun src/index.ts",
    "version:set": "node scripts/set-version.mjs",
    "version:check": "node scripts/set-version.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:commits": "commitlint --from origin/master --to HEAD",
    "test:e2e:readonly": "bun scripts/e2e-readonly.ts",
    "test:e2e:help": "bun scripts/e2e-help.ts",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:strict": "eslint src/program.ts src/commands/global-options.ts src/commands/config*.ts src/formatters/toon.ts src/formatters/runtime-fields.ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "smoke:npx": "node scripts/smoke-npx.mjs",
    "smoke:bunx": "node scripts/smoke-bunx.mjs",
    "audit:history": "node scripts/scan-history-secrets.mjs",
    "audit:version-history": "node scripts/audit-version-history.mjs",
    "changelog:pm": "pm-changelog --pm-root .agents/pm --pm-bin ./node_modules/.bin/pm --output CHANGELOG.md --title Changelog --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/monica-cli/blob/master/.agents/pm",
    "changelog:pm:check": "pm-changelog --pm-root .agents/pm --pm-bin ./node_modules/.bin/pm --output CHANGELOG.md --title Changelog --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/monica-cli/blob/master/.agents/pm --check",
    "changelog:preservation:check": "node scripts/verify-changelog-preservation.mjs",
    "workflows:check": "node scripts/validate-workflows.mjs",
    "release:pipeline": "node scripts/release/run-release-pipeline.mjs",
    "release:pipeline:dry-run": "node scripts/release/run-release-pipeline.mjs --dry-run",
    "release:verify-published": "node scripts/release/verify-published-release.mjs",
    "verify:release": "bun run version:check && bun run changelog:pm:check && bun run changelog:preservation:check && bun run workflows:check && bun run typecheck && bun run lint && bun run build && bun run test && bun run smoke:npx && bun run smoke:bunx && bun run audit:history && bun run audit:version-history",
    "prepublishOnly": "bun run version:check && bun run clean && bun run lint && bun run build && bun run test && bun run smoke:npx && bun run smoke:bunx",
    "release": "bun run verify:release",
    "version:check:format": "node scripts/set-version.mjs --format-only"
  },
  "keywords": [
    "monica",
    "crm",
    "cli",
    "api",
    "toon",
    "personal-crm",
    "contact-management"
  ],
  "author": "unbraind",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unbraind/monica-cli.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/monica-cli/issues"
  },
  "homepage": "https://github.com/unbraind/monica-cli#readme",
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@unbrained/pm-cli": "2026.7.21",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "pm-changelog": "2026.7.18",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
