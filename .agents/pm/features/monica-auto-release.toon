tests[4]:
  - command: "bun run changelog:pm:check && bun run changelog:preservation:check"
    scope: project
    timeout_seconds: 300
    pm_context_mode: tracker
  - command: bun run typecheck && bun run lint && bun run build && bun run test
    scope: project
    timeout_seconds: 1800
  - command: "bun run workflows:check"
    scope: project
    timeout_seconds: 300
  - command: bun test tests/release-pipeline.test.ts
    scope: project
    timeout_seconds: 300
docs[2]{path,scope,note}:
