{"ts":"2026-07-22T04:52:43.942Z","author":"codex-root","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/2","value":{"created_at":"2026-07-22T04:52:43.942Z","author":"codex-root","text":"Dogfood exposed that the read-only E2E harness treated the newly diagnosed Monica infrastructure message as an unexpected command failure even after capability probing proved the instance unhealthy. Updated the harness to classify that exact server failure as expected unavailability; write guards remain mandatory passes."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-22T04:52:43.942Z"}],"before_hash":"057a7a838c2ce7552077f8df03b9236fab1c2dbb2437b81620443065f1340a5f","after_hash":"3cfe90e174ca089e58270841f06b1387ce335500338dcddcde43c85871da1b25"}
