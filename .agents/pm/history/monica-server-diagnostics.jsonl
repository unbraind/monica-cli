{"ts":"2026-07-22T04:48:55.710Z","author":"codex-root","op":"learning_add","patch":[{"op":"add","path":"/metadata/learnings/1","value":{"created_at":"2026-07-22T04:48:55.709Z","author":"codex-root","text":"Capability probe payloads are the best canonical attachment point because downstream agent-context and instance-profile surfaces inherit the diagnosis while cached reports remain self-describing."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-22T04:48:55.710Z"}],"before_hash":"3f63745936b43347f062f8cb9f7daf67a3110abde00ef229f0d43c76907f830d","after_hash":"f0c39f51684017b90a7e4ce4db0c39b948aed751644a3843fcb40f11db8ea7e4"}
