{
  "version": "v1",
  "baseUrl": "https://app.monicahq.com/api",
  "authentication": {
    "type": "Bearer Token",
    "header": "Authorization: Bearer OAUTH-TOKEN"
  },
  "pagination": {
    "defaultPerPage": 10,
    "maxPerPage": 100,
    "parameters": ["page", "limit"],
    "response": {
      "links": ["first", "last", "prev", "next"],
      "meta": ["current_page", "from", "last_page", "path", "per_page", "to", "total"]
    }
  },
  "rateLimit": {
    "limit": 60,
    "window": "per minute",
    "headers": ["X-RateLimit-Limit", "X-RateLimit-Remaining", "Retry-After"]
  },
  "resources": {
    "activities": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/activities",
          "description": "List all activities in account",
          "parameters": [
            {"name": "limit", "type": "integer", "required": false},
            {"name": "page", "type": "integer", "required": false}
          ],
          "response": "PaginatedResponse<Activity>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/activities",
          "description": "List activities for a contact",
          "response": "PaginatedResponse<Activity>"
        },
        {
          "method": "GET",
          "path": "/activities/:id",
          "description": "Get a specific activity",
          "response": "Activity"
        },
        {
          "method": "POST",
          "path": "/activities",
          "description": "Create an activity",
          "input": {
            "activity_type_id": {"type": "integer", "required": true},
            "summary": {"type": "string", "required": true, "maxLength": 255},
            "description": {"type": "string", "required": false, "maxLength": 1000000},
            "happened_at": {"type": "string", "required": true, "format": "YYYY-MM-DD"},
            "contacts": {"type": "array", "required": true, "description": "Array of contact IDs"},
            "emotions": {"type": "array", "required": false}
          },
          "response": "Activity"
        },
        {
          "method": "PUT",
          "path": "/activities/:id",
          "description": "Update an activity",
          "input": "same as POST",
          "response": "Activity"
        },
        {
          "method": "DELETE",
          "path": "/activities/:id",
          "description": "Delete an activity",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "activityTypes": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/activitytypes",
          "description": "List all activity types",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<ActivityType>"
        },
        {
          "method": "GET",
          "path": "/activitytypes/:id",
          "description": "Get a specific activity type",
          "response": "ActivityType"
        },
        {
          "method": "POST",
          "path": "/activitytypes",
          "description": "Create an activity type",
          "input": {
            "name": {"type": "string", "required": true, "maxLength": 255},
            "activity_type_category_id": {"type": "integer", "required": true}
          },
          "response": "ActivityType"
        },
        {
          "method": "PUT",
          "path": "/activitytypes/:id",
          "description": "Update an activity type",
          "input": "same as POST",
          "response": "ActivityType"
        },
        {
          "method": "DELETE",
          "path": "/activitytypes/:id",
          "description": "Delete an activity type",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "activityTypeCategories": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/activitytypecategories",
          "description": "List all activity type categories",
          "response": "PaginatedResponse<ActivityTypeCategory>"
        },
        {
          "method": "GET",
          "path": "/activitytypecategories/:id",
          "description": "Get a specific activity type category",
          "response": "ActivityTypeCategory"
        },
        {
          "method": "POST",
          "path": "/activitytypecategories",
          "description": "Create an activity type category",
          "input": {"name": {"type": "string", "required": true, "maxLength": 255}},
          "response": "ActivityTypeCategory"
        },
        {
          "method": "PUT",
          "path": "/activitytypecategories/:id",
          "description": "Update an activity type category",
          "input": "same as POST",
          "response": "ActivityTypeCategory"
        },
        {
          "method": "DELETE",
          "path": "/activitytypecategories/:id",
          "description": "Delete an activity type category",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "addresses": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/contacts/:id/addresses",
          "description": "List addresses for a contact",
          "response": "PaginatedResponse<Address>"
        },
        {
          "method": "GET",
          "path": "/addresses/:id",
          "description": "Get a specific address",
          "response": "Address"
        },
        {
          "method": "POST",
          "path": "/addresses",
          "description": "Create an address",
          "input": {
            "name": {"type": "string", "required": true, "maxLength": 255},
            "street": {"type": "string", "required": false, "maxLength": 255},
            "city": {"type": "string", "required": false, "maxLength": 255},
            "province": {"type": "string", "required": false, "maxLength": 255},
            "postal_code": {"type": "string", "required": false, "maxLength": 255},
            "country": {"type": "string", "required": false, "maxLength": 3, "description": "Country ISO code"},
            "contact_id": {"type": "integer", "required": true}
          },
          "response": "Address"
        },
        {
          "method": "PUT",
          "path": "/addresses/:id",
          "description": "Update an address",
          "input": "same as POST",
          "response": "Address"
        },
        {
          "method": "DELETE",
          "path": "/addresses/:id",
          "description": "Delete an address",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "auditLogs": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/logs",
          "description": "List all audit logs in account",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<AuditLog>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/logs",
          "description": "List audit logs for a contact",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<AuditLog>"
        }
      ]
    },
    "calls": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/calls",
          "description": "List all calls in account",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<Call>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/calls",
          "description": "List calls for a contact",
          "response": "PaginatedResponse<Call>"
        },
        {
          "method": "GET",
          "path": "/calls/:id",
          "description": "Get a specific call",
          "response": "Call"
        },
        {
          "method": "POST",
          "path": "/calls",
          "description": "Create a call",
          "input": {
            "content": {"type": "string", "required": true, "maxLength": 100000},
            "contact_id": {"type": "integer", "required": true},
            "called_at": {"type": "string", "required": true, "format": "YYYY-MM-DD"}
          },
          "response": "Call"
        },
        {
          "method": "PUT",
          "path": "/calls/:id",
          "description": "Update a call",
          "input": "same as POST",
          "response": "Call"
        },
        {
          "method": "DELETE",
          "path": "/calls/:id",
          "description": "Delete a call",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "companies": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/companies",
          "description": "List all companies",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<Company>"
        },
        {
          "method": "GET",
          "path": "/companies/:id",
          "description": "Get a specific company",
          "response": "Company"
        },
        {
          "method": "POST",
          "path": "/companies",
          "description": "Create a company",
          "input": {
            "name": {"type": "string", "required": true, "maxLength": 255},
            "website": {"type": "string", "required": false, "maxLength": 255},
            "number_of_employees": {"type": "integer", "required": false}
          },
          "response": "Company"
        },
        {
          "method": "PUT",
          "path": "/companies/:id",
          "description": "Update a company",
          "input": "same as POST",
          "response": "Company"
        },
        {
          "method": "DELETE",
          "path": "/companies/:id",
          "description": "Delete a company",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "compliance": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/compliance",
          "description": "List all terms and privacy policies",
          "response": "PaginatedResponse<Term>"
        },
        {
          "method": "GET",
          "path": "/compliance/:id",
          "description": "Get a specific term/privacy policy",
          "response": "Term"
        },
        {
          "method": "GET",
          "path": "/me/compliance",
          "description": "Get compliance status for authenticated user",
          "response": "Array of compliance status objects"
        },
        {
          "method": "GET",
          "path": "/me/compliance/:id",
          "description": "Get status of specific policy for user",
          "response": "Compliance status object"
        },
        {
          "method": "POST",
          "path": "/me/compliance",
          "description": "Sign latest compliance policy",
          "input": {"ip_address": {"type": "string", "required": true}},
          "response": "Compliance status object"
        }
      ]
    },
    "contacts": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/contacts",
          "description": "List all contacts",
          "parameters": [
            {"name": "limit", "type": "integer"},
            {"name": "page", "type": "integer"},
            {"name": "query", "type": "string", "description": "Search query"},
            {"name": "sort", "type": "string", "enum": ["created_at", "-created_at", "updated_at", "-updated_at"]}
          ],
          "response": "PaginatedResponse<Contact>"
        },
        {
          "method": "GET",
          "path": "/tags/:id/contacts",
          "description": "List contacts for a tag",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<Contact>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id",
          "description": "Get a specific contact",
          "parameters": [{"name": "with", "type": "string", "description": "Use 'contactfields' to include contact fields"}],
          "response": "Contact"
        },
        {
          "method": "POST",
          "path": "/contacts",
          "description": "Create a contact",
          "input": {
            "first_name": {"type": "string", "required": true, "maxLength": 50},
            "last_name": {"type": "string", "required": false, "maxLength": 100},
            "nickname": {"type": "string", "required": false, "maxLength": 100},
            "gender_id": {"type": "integer", "required": true},
            "birthdate_day": {"type": "integer", "required": false},
            "birthdate_month": {"type": "integer", "required": false},
            "birthdate_year": {"type": "integer", "required": false},
            "birthdate_is_age_based": {"type": "boolean", "required": false},
            "is_birthdate_known": {"type": "boolean", "required": true},
            "birthdate_age": {"type": "integer", "required": false},
            "is_partial": {"type": "boolean", "required": false},
            "is_deceased": {"type": "boolean", "required": true},
            "is_deceased_date_known": {"type": "boolean", "required": true},
            "deceased_date_add_reminder": {"type": "boolean", "required": false},
            "deceased_date_day": {"type": "integer", "required": false},
            "deceased_date_month": {"type": "integer", "required": false},
            "deceased_date_year": {"type": "integer", "required": false},
            "deceased_date_is_age_based": {"type": "boolean", "required": false}
          },
          "response": "Contact"
        },
        {
          "method": "PUT",
          "path": "/contacts/:id",
          "description": "Update a contact",
          "input": "same as POST",
          "response": "Contact"
        },
        {
          "method": "PUT",
          "path": "/contacts/:id/career",
          "description": "Update contact career",
          "input": {
            "job": {"type": "string", "required": false},
            "company": {"type": "string", "required": false}
          },
          "response": "Contact"
        },
        {
          "method": "DELETE",
          "path": "/contacts/:id",
          "description": "Delete a contact",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ],
      "nestedResources": [
        {"path": "/contacts/:id/activities", "resource": "activities"},
        {"path": "/contacts/:id/addresses", "resource": "addresses"},
        {"path": "/contacts/:id/calls", "resource": "calls"},
        {"path": "/contacts/:id/conversations", "resource": "conversations"},
        {"path": "/contacts/:id/contactfields", "resource": "contactFields"},
        {"path": "/contacts/:id/documents", "resource": "documents"},
        {"path": "/contacts/:id/gifts", "resource": "gifts"},
        {"path": "/contacts/:id/logs", "resource": "auditLogs"},
        {"path": "/contacts/:id/notes", "resource": "notes"},
        {"path": "/contacts/:id/photos", "resource": "photos"},
        {"path": "/contacts/:id/reminders", "resource": "reminders"},
        {"path": "/contacts/:id/relationships", "resource": "relationships"},
        {"path": "/contacts/:id/tasks", "resource": "tasks"}
      ]
    },
    "contactFields": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/contacts/:id/contactfields",
          "description": "List contact fields for a contact",
          "response": "PaginatedResponse<ContactField>"
        },
        {
          "method": "GET",
          "path": "/contactfields/:id",
          "description": "Get a specific contact field",
          "response": "ContactField"
        },
        {
          "method": "POST",
          "path": "/contactfields",
          "description": "Create a contact field",
          "input": {
            "data": {"type": "string", "required": true, "maxLength": 255},
            "contact_field_type_id": {"type": "integer", "required": true},
            "contact_id": {"type": "integer", "required": true}
          },
          "response": "ContactField"
        },
        {
          "method": "PUT",
          "path": "/contactfields/:id",
          "description": "Update a contact field",
          "input": "same as POST",
          "response": "ContactField"
        },
        {
          "method": "DELETE",
          "path": "/contactfields/:id",
          "description": "Delete a contact field",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "contactFieldTypes": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/contactfieldtypes",
          "description": "List all contact field types",
          "response": "PaginatedResponse<ContactFieldType>"
        },
        {
          "method": "GET",
          "path": "/contactfieldtypes/:id",
          "description": "Get a specific contact field type",
          "response": "ContactFieldType"
        },
        {
          "method": "POST",
          "path": "/contactfieldtypes",
          "description": "Create a contact field type",
          "input": {
            "name": {"type": "string", "required": true, "maxLength": 255},
            "fontawesome_icon": {"type": "string", "required": false, "maxLength": 255},
            "protocol": {"type": "string", "required": false, "maxLength": 255},
            "delible": {"type": "integer", "required": false, "enum": [0, 1]},
            "type": {"type": "string", "required": false, "maxLength": 255}
          },
          "response": "ContactFieldType"
        },
        {
          "method": "PUT",
          "path": "/contactfieldtypes/:id",
          "description": "Update a contact field type",
          "input": "same as POST",
          "response": "ContactFieldType"
        },
        {
          "method": "DELETE",
          "path": "/contactfieldtypes/:id",
          "description": "Delete a contact field type",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "conversations": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/conversations",
          "description": "List all conversations",
          "response": "PaginatedResponse<Conversation>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/conversations",
          "description": "List conversations for a contact",
          "response": "PaginatedResponse<Conversation>"
        },
        {
          "method": "GET",
          "path": "/conversations/:id",
          "description": "Get a specific conversation with messages",
          "response": "Conversation"
        },
        {
          "method": "POST",
          "path": "/conversations",
          "description": "Create a conversation",
          "input": {
            "happened_at": {"type": "string", "required": true, "format": "YYYY-MM-DD"},
            "contact_field_type_id": {"type": "integer", "required": true},
            "contact_id": {"type": "integer", "required": true}
          },
          "response": "Conversation"
        },
        {
          "method": "PUT",
          "path": "/conversations/:id",
          "description": "Update a conversation",
          "input": {"happened_at": {"type": "string", "required": true, "format": "YYYY-MM-DD"}},
          "response": "Conversation"
        },
        {
          "method": "DELETE",
          "path": "/conversations/:id",
          "description": "Delete a conversation",
          "response": {"deleted": "boolean", "id": "integer"}
        },
        {
          "method": "POST",
          "path": "/conversations/:id/messages",
          "description": "Add a message to conversation",
          "input": {
            "written_at": {"type": "string", "required": true, "format": "YYYY-MM-DD"},
            "written_by_me": {"type": "boolean", "required": true},
            "content": {"type": "string", "required": true},
            "contact_id": {"type": "integer", "required": true}
          },
          "response": "Conversation"
        },
        {
          "method": "PUT",
          "path": "/conversations/:id/messages/:messageId",
          "description": "Update a message in conversation",
          "input": "same as POST message",
          "response": "Conversation"
        },
        {
          "method": "DELETE",
          "path": "/conversations/:id/messages/:messageId",
          "description": "Delete a message from conversation",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "countries": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/countries",
          "description": "List all countries",
          "response": "Object with country ISO codes as keys"
        }
      ]
    },
    "currencies": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/currencies",
          "description": "List all currencies",
          "response": "PaginatedResponse<Currency>"
        },
        {
          "method": "GET",
          "path": "/currencies/:id",
          "description": "Get a specific currency",
          "response": "Currency"
        }
      ]
    },
    "debts": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/debts",
          "description": "List all debts",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<Debt>"
        },
        {
          "method": "GET",
          "path": "/debts/:id",
          "description": "Get a specific debt",
          "response": "Debt"
        },
        {
          "method": "POST",
          "path": "/debts",
          "description": "Create a debt",
          "input": {
            "contact_id": {"type": "integer", "required": true},
            "in_debt": {"type": "string", "required": true, "enum": ["yes", "no"]},
            "status": {"type": "string", "required": true, "enum": ["inprogress", "complete"]},
            "amount": {"type": "integer", "required": true},
            "reason": {"type": "string", "required": false, "maxLength": 10000000}
          },
          "response": "Debt"
        },
        {
          "method": "PUT",
          "path": "/debts/:id",
          "description": "Update a debt",
          "input": "same as POST",
          "response": "Debt"
        },
        {
          "method": "DELETE",
          "path": "/debts/:id",
          "description": "Delete a debt",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "documents": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/documents",
          "description": "List all documents in account",
          "response": "PaginatedResponse<Document>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/documents",
          "description": "List documents for a contact",
          "response": "PaginatedResponse<Document>"
        },
        {
          "method": "GET",
          "path": "/documents/:id",
          "description": "Get a specific document",
          "response": "Document"
        },
        {
          "method": "POST",
          "path": "/documents",
          "description": "Create/upload a document",
          "contentType": "multipart/form-data",
          "input": {
            "contact_id": {"type": "integer", "required": true},
            "document": {"type": "file", "required": true}
          },
          "response": "Document"
        },
        {
          "method": "DELETE",
          "path": "/documents/:id",
          "description": "Delete a document",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "genders": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/genders",
          "description": "List all genders",
          "response": "PaginatedResponse<Gender>"
        },
        {
          "method": "GET",
          "path": "/genders/:id",
          "description": "Get a specific gender",
          "response": "Gender"
        },
        {
          "method": "POST",
          "path": "/genders",
          "description": "Create a gender",
          "input": {"name": {"type": "string", "required": true, "maxLength": 255}},
          "response": "Gender"
        },
        {
          "method": "PUT",
          "path": "/genders/:id",
          "description": "Update a gender",
          "input": "same as POST",
          "response": "Gender"
        },
        {
          "method": "DELETE",
          "path": "/genders/:id",
          "description": "Delete a gender",
          "response": {"deleted": "boolean", "id": "integer"}
        }
      ]
    },
    "gifts": {
      "endpoints": [
        {
          "method": "GET",
          "path": "/gifts",
          "description": "List all gifts",
          "parameters": [{"name": "limit", "type": "integer"}, {"name": "page", "type": "integer"}],
          "response": "PaginatedResponse<Gift>"
        },
        {
          "method": "GET",
          "path": "/contacts/:id/gifts",
          "description": "List gifts for a contact",
          "response": "PaginatedResponse<Gift>"
        },
        {
          "method": "GET",
          "path": "/gifts/:id",
          "description": "Get a specific gift",
          "response": "Gift"
        },
        {
          "method": "POST",
          "path": "/gifts",
          "description": "Create a gift",
          "input": {
            "contact_id": {"type": "integer", "required": true},
            "recipient_id": {"type": "integer", "required": false},
            "name": {"type": "string", "required": true, "maxLength": 255},
            "comment": {"type": "string", "required": false, "maxLength": 1000000},
            "url": {"type": "string", "required": false, "maxLength": 1000000},
            "amount": {"type": "number", "required": false},
            "status": {"type": "string", "required": true, "enum": ["idea", "offered", "received"]},
            "date": {"type": "string", "required": false, "format": "YYYY-MM-DD"}
